# ─── Server ───────────────────────────────────────────────
PORT=4000
NODE_ENV=development
# Origin of the React frontend (CORS is locked to this).
CLIENT_ORIGIN=http://localhost:5173

# ─── Security ─────────────────────────────────────────────
# Generate strong values in real environments, e.g. `openssl rand -hex 32`
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=8h
# Issuer name shown inside Google Authenticator
MFA_ISSUER=CAB-Sessions

# ─── Database ─────────────────────────────────────────────
# SQLite file path (relative to backend/). Swap for an Azure SQL/MSSQL DSN later.
DB_FILE=./data/cab.sqlite

# ─── Notifications (email) ────────────────────────────────
# POC uses a console "email" transport. Set these to wire a real SMTP later.
MAIL_FROM=cab-no-reply@cab.local
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
