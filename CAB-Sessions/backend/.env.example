# ─── Server ───────────────────────────────────────────────
PORT=4000
NODE_ENV=development
# Origin of the React frontend (CORS is locked to this).
CLIENT_ORIGIN=http://localhost:5173

# ─── Security ─────────────────────────────────────────────
# Generate strong values in real environments, e.g. `openssl rand -hex 32`
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=8h
# Issuer name shown inside Google Authenticator
MFA_ISSUER=CAB-Sessions

# ─── Database (PostgreSQL) ────────────────────────────────
# Local dev: start Postgres with `docker compose up -d`, then use:
DATABASE_URL=postgres://cab:cab@localhost:5432/cab
# On Render: link a Postgres instance and DATABASE_URL is injected automatically.
# Set DATABASE_SSL=true to force TLS (Render managed Postgres requires it).
DATABASE_SSL=

# ─── Notifications (email) ────────────────────────────────
# POC uses a console "email" transport. Set these to wire a real SMTP later.
MAIL_FROM=cab-no-reply@cab.local
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# ─── AI assistant (Claude / Anthropic) ────────────────────
# If empty, AI features self-disable and the rest of the app keeps working.
# Key stays on the backend only — never expose it to the frontend.
ANTHROPIC_API_KEY=
# Model for CAB AI (draft / feedback / report). Default: Haiku 4.5 (fast, low cost).
AI_MODEL=claude-haiku-4-5

# ─── Azure DevOps (Azure Boards) ──────────────────────────
# Read-only pull of Epics/Features/Tasks. PAT stays on the backend only.
# If any are empty, the ADO feature self-disables.
ADO_ORG_URL=https://proyectoskeyron.visualstudio.com
ADO_PROJECT=CAB
ADO_PAT=
ADO_TYPES=Epic,Feature,Task

# ─── Microsoft Entra ID (Azure AD) SSO ────────────────────
# tenantId + clientId are public identifiers (no secret for SPA/PKCE).
# If empty, Microsoft sign-in is hidden and local login still works.
ENTRA_TENANT_ID=80a5b8d9-6288-42f7-89cb-ae9dd6103960
ENTRA_CLIENT_ID=6faf5833-3fa7-4826-8539-c127391541ae
# Comma-separated emails granted the Admin role on their first Microsoft sign-in.
ENTRA_ADMIN_EMAILS=
